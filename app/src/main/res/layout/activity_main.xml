<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Block distracting apps until you wait, solve, or pay."
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnEnableAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Accessibility" />

    <Button
        android:id="@+id/btnSelectApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Apps"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnResetCredits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Credits"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnResetBlockedApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Blocked Apps"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_not_enabled"
        android:textSize="14sp"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvCredits"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Credits: 10"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/tvBlockedAppsCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Blocked apps: 0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

</LinearLayout>