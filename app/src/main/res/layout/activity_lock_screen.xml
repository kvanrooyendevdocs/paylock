<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvBlockedMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Opening this app costs you."
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnWait"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wait 60 Seconds" />

    <Button
        android:id="@+id/btnChallenge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Solve Challenge"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnPay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Unlock Instantly"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/tvCreditInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Credits available: 10 (cost: 1)"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvChallengeQuestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etChallengeAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter answer"
        android:inputType="number"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnSubmitAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Answer"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

</LinearLayout>